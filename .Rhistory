require(graphics)
pairs(d, panel = panel.smooth, main = 'USArrests',pch=20)
ds <- as.data.frame(scale(d))
plot(ds, pch=20)
boxplot(ds) # Aquí se ve claramente que ya están estandarizadas
n<-50
PCA<-princomp(d,cor=TRUE)
L<-PCA$loadings
S<-PCA$scores
Y1<-S[,1]
Y2<-S[,2]
biplot(PCA,pc.biplot=TRUE,cex=0.5)
biplot(PCA,pc.biplot=TRUE,xlabs=1:n,cex=0.5)
plot(Y1,Y2,pch=20)
text(Y1,Y2-0.2,labels=row.names(d),cex=0.5,col='red')
# Como ya hemos visto en clase, el método más utilizado es el de k-means, que va moviendo los centorides
set.seed(1234)
CA1<-kmeans(ds,centers=2,nstar=10) # nstar nos dice cuantas veces va a realizar el proceso para no caer en mínimos locales
CA1 # nos fijamos en cluster means, como hemos estandarizado los datos, el 0 representa el punto medio
# Guardamos los centroides
C1<-CA1$centers[1,]
C2<-CA1$centers[2,]
# Ahora incluimos el grupo al que pertenecen en la tabla
Y<-CA1$cluster
d1<-data.frame(ds,Y)
View(d1)
# Para representar los grupos hacemos:
plot(ds[,1:2],col=CA1$cluster,pch=20)
plot(ds[,3:4],col=CA1$cluster,pch=20)
plot(ds,col=CA1$cluster,pch=20)
plot(Y1,Y2,col=CA1$cluster,pch=20)
text(Y1,Y2-0.2,labels=row.names(d),cex=0.5) # observamos que Y1 (primera componente principal) discrimina mucho mejor los dos grupos
# Podemos usar distintos símbolos para cada grupo con:
plot(ds[,1:2],pch=as.integer(CA1$cluster),col=CA1$cluster)
legend('topleft',legend=c('cluster1','cluster2'),pch=1:2,cex=0.7)
# Para incluir los centroides podemos hacer:
plot(ds[,1:2],col=CA1$cluster,pch=20)
points(C1[1],C1[2],col='green')
text(C1[1],C1[2]+0.2,'C1',col='green')
points(C2[1],C2[2],col='green')
text(C2[1],C2[2]+0.2,'C2',col='green')
plot(ds[,3:4],col=CA1$cluster,pch=20)
points(C1[3],C1[4],col='green')
text(C1[3],C1[4]+0.2,'C1',col='green')
points(C2[3],C2[4],col='green')
text(C2[3],C2[4]+0.2,'C2',col='green')
# Si queremos gráficos más detallados podemos hacerlos con algunas librerías
library(cluster)
clusplot(ds,CA1$cluster,color=T,shade=T,labels=2,cex=0.5,lines=0)
# Para saber las sumas de las distancias al cuadrado de los puntos a su centroide
CA1$withinss # Podemos observar que el segundo grupo está algo más disperso
# La suma de las distancias a los centroides más cercanos podemos calcularla con
CA1$tot.withinss # esto nos da la suma de todo
# También podemos obtener la suma de las distancias al cuadrado sin grupos con
CA1$totss
# Ahora podemos calcular la disminución que se ha producido al agruparse:
1 - (CA1$tot.withinss/CA1$totss) # con dos grupos, la variablidad se reduce en un 47.52%
