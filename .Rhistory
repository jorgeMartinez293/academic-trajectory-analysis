# --- Librerías para importar ---
library(mvtnorm) # para obtener funciones de densidad de datos de la distribución normal
# --- Librerías para importar ---
library(mvtnorm) # para obtener funciones de densidad de datos de la distribución normal
# --- Librerías para importar ---
library(mvtnorm) # para obtener funciones de densidad de datos de la distribución normal
# --- Librerías para importar ---
library(mvtnorm) # para obtener funciones de densidad de datos de la distribución normal
# --- Librerías para importar ---
library(mvtnorm) # para obtener funciones de densidad de datos de la distribución normal
# -- Necesitamos una matriz de covarianza, una media y un valor ---
V<-matrix(NA,2,2) # Creamos la matriz
V[1,]<-c(1,1/2) # Rellenamos la matriz
V[2,]<-c(1/2,1)
mu<-c(0,0) # Definimos una media
x<-c(1,1) # Definimos una x
dmvnorm(x,mu,V) # función de densidad
pmvnorm(lower=-Inf,upper=x,mean=mu,sigma=V) # Función de distribución.
# --- Para mostrarlo en una gráfica ---
# Establecemos una función que nos dé la densidad en función de la distribución
f<-function(x,y)
dmvnorm(data.frame(x,y),mu,sigma=V)
# Establecemos los límites del gráfico
x<-seq(-3,3,length=50)
y<-seq(-3,3,length=50)
z<-outer(x,y,f)
# Mostramos el gráfico
persp(x,y,z,xlab='x',ylab='y',zlab='f(x,y)',col='red',theta=0)
# También se puede ver el gráfico desde otro ángulo, vamos a hacerlo con la función de densidad
set.seed(123) # Establecemos una semilla
d <- rmvnorm(50, mu, V) # Como solo coge una varibale y saca otra, podemos no hacer una función
plot(d,xlab="X1",ylab="X2",pch=20,xlim=c(-3,3),lim=c(-3,3)) # Mostrar la gráfica de los datos R2
contour(x,y,z,add=TRUE,col='red') # Añadir un contorno para los datos y poder ver la forma
# --- Obtener estadísticos de los datos ---
summary(d)
cor(d) # matriz de correlaciones muestrales
# Cuasi-varianzas
var(d[,1])
var(d[,2])
cov(d[,1],d[,2]) # cuasi-covarianzas
# --- Para test de normalidad ---
library(mvnormtest)
mshapiro.test(t(d)) # aquí miras el p-valor para saber si puedes dar por válida tu hipótesis nula (p-valor<0.05 -> normal)
# --- distancias de mahalanobis --- (para poder detectar datos atípicos)
dM1 <- mahalanobis(d, mu, V) # todas estas distancias están al cuadrado
dM2 <- mahalanobis(d,colMeans(d),cov(d))
max(dM1) # este es el máximo
which.max(dM1) # este es el dato con el máximo
max(dM2)
which.max(dM2)
# --- Añadir etiqueta al gráfico (con el dato atípico) ---
text(d[49,1],d[49,2]-0.15,'49',cex=0.75)
which.max(dM2)
# --- Añadir etiqueta al gráfico (con el dato atípico) ---
text(d[49,1],d[49,2]-0.15,'49',cex=0.75)
# Visualizar las distancias y verlas ordenadas
View(data.frame(d[,1],d[,2],dM1,dM2))
# --- Datos multivariantes ---
d <- iris
# Podemos ir a una columna del dataframe con $ que es lo mismo que d[,1]
mean(d$Sepal.Length)
# Para calcular el vector de medias y la matriz de covarianzas:
