# La última columna es cualitativa, así que deberíamos hacer los calculos por especie, no en general.
tapply(d$Sepal.Length, d$Species,mean) # Separando por especies, dame la media
tapply(d$Sepal.Length,d$Species,summary)
# Una vez divididos en especies, el diagrama de caja y bigotes suele ser una buena forma de observarlo:
boxplot(d$Sepal.Length~d$Species,xlab='Especies',ylab='Long.sepalo')
# Para separar los datos por especies podemos hacer:
list <- split(d,d$Species)
list2env(list,.GlobalEnv) # Así creamos tres grupos con los nombres de los tipos.
